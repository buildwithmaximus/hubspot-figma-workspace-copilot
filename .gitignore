.vscode/settings.json

# HubSpot CLI config with credentials — never commit after adding credentials
hubspot.config.yml

# Sensitive files
.env
*.token

# Brand assets (large files)
brand/*.pdf
brand/*.woff
brand/*.woff2
brand/*.otf
brand/*.ttf

# OS files
.DS_Store
Thumbs.db
